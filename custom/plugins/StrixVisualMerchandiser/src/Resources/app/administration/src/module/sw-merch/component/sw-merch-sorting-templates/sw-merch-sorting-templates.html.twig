<div class="sw-merch-sorting-templates">
    <!-- Per-category link -->
    <mt-card>
        <template #toolbar>
            <div style="display:flex;justify-content:space-between;align-items:center;width:100%">
                <h3>{{ $tc('sw-merch.sorting.title') }} — Category</h3>
            </div>
        </template>

        <div v-if="isLoading" style="padding:40px;text-align:center"><mt-loader size="30px" /></div>

        <div v-else-if="linkedTemplate" style="padding:16px">
            <!-- Template header -->
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
                <div style="display:flex;align-items:center;gap:10px">
                    <span style="font-weight:600;font-size:15px">{{ linkedTemplate.name }}</span>
                    <span style="font-size:11px;color:#758698;background:#f0f2f5;padding:2px 8px;border-radius:10px">
                        {{ linkedTemplate.sortOptions.length }} options
                    </span>
                </div>
                <mt-button size="small" variant="ghost-danger" @click="onUnlinkTemplate">
                    <mt-icon name="regular-trash" size="14" />
                </mt-button>
            </div>

            <!-- Override mode -->
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;padding:10px 12px;background:#f9fafb;border-radius:6px">
                <span style="font-size:12px;font-weight:600;color:#374151;white-space:nowrap">Mode:</span>
                <mt-select
                    :model-value="categoryLink.overrideMode"
                    :options="overrideModeOptions"
                    :help-text="$tc('sw-merch.sorting.helpText.overrideMode')"
                    size="small"
                    style="flex:1;max-width:200px"
                    @update:model-value="onOverrideModeChange"
                />
            </div>

            <!-- Sort options list -->
            <div style="display:flex;flex-direction:column;gap:6px">
                <div
                    v-for="opt in linkedTemplate.sortOptions"
                    :key="opt.position"
                    style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border:1px solid #e8ecf0;border-radius:6px;font-size:13px"
                >
                    <span style="font-weight:500">{{ opt.label?.en || 'Unnamed' }}</span>
                    <span style="font-size:11px;color:#758698;background:#f0f2f5;padding:2px 8px;border-radius:10px">
                        <template v-if="opt.type === 'shopware'">{{ opt.field }} {{ opt.direction }}</template>
                        <template v-else>{{ getRuleName(opt.ruleId) }}</template>
                    </span>
                </div>
            </div>
        </div>

        <div v-else style="padding:32px;text-align:center;color:#758698">
            <mt-icon name="regular-image" size="36" style="opacity:0.3;margin-bottom:8px" />
            <p style="margin:0 0 12px">{{ $tc('sw-merch.sorting.noLinkedTemplate') }}</p>
            <mt-select
                v-if="canEdit && templates.length > 0"
                :placeholder="$tc('sw-merch.general.linkTemplate')"
                :options="templates.map(t => ({ value: t.id, label: t.name }))"
                @update:model-value="onLinkTemplate"
                size="small"
                style="max-width:300px;margin:0 auto"
            />
        </div>
    </mt-card>

    <!-- Global templates -->
    <mt-card>
        <template #toolbar>
            <div style="display:flex;justify-content:space-between;align-items:center;width:100%">
                <h3>All Sorting Templates (Global)</h3>
                <mt-button v-if="canEdit" variant="primary" size="small" @click="onCreateTemplate">
                    {{ $tc('sw-merch.sorting.create') }}
                </mt-button>
            </div>
        </template>

        <div v-for="template in templates" :key="template.id" style="display:flex;align-items:center;gap:12px;padding:10px 12px;border-bottom:1px solid #e8ecf0">
            <div style="flex:1">
                <strong>{{ template.name }}</strong>
                <small style="margin-left:8px;color:#758698">{{ template.sortOptions.length }} options</small>
            </div>
            <mt-button v-if="canEdit" size="small" variant="ghost" @click="onEditTemplate(template)">
                <mt-icon name="regular-pencil-s" size="16" />
            </mt-button>
            <mt-button v-if="canEdit" size="small" variant="ghost-danger" @click="onDeleteTemplate(template)">
                <mt-icon name="regular-trash" size="16" />
            </mt-button>
        </div>
    </mt-card>

    <!-- Create/Edit Modal -->
    <sw-modal v-if="showCreateModal" :title="editingTemplate ? 'Edit Template' : $tc('sw-merch.sorting.create')" variant="large" @modal-close="onCloseModal">
        <div style="display:flex;flex-direction:column;gap:16px">
            <mt-text-field label="Name" :model-value="newTemplate.name" @update:model-value="newTemplate.name = $event" required />
            <mt-switch label="Active" :model-value="newTemplate.active" @update:model-value="newTemplate.active = $event" />

            <h4 style="margin:8px 0 0">Sort Options</h4>
            <div v-for="(opt, index) in newTemplate.sortOptions" :key="index" style="display:flex;gap:8px;align-items:center;padding:8px;border:1px solid #d1d9e0;border-radius:6px">
                <mt-text-field label="Label (EN)" :model-value="opt.label.en" @update:model-value="opt.label.en = $event" size="small" style="width:140px" />
                <mt-select label="Type" :model-value="opt.type" :options="sortTypeOptions" size="small" style="width:140px" @update:model-value="(v) => opt.type = v" />

                <template v-if="opt.type === 'shopware'">
                    <mt-select label="Field" :model-value="opt.field" :options="shopwareFieldOptions" size="small" style="width:120px" @update:model-value="(v) => opt.field = v" />
                    <mt-select
                        label="Direction"
                        :model-value="opt.direction"
                        :options="[{ value: 'asc', label: 'ASC' }, { value: 'desc', label: 'DESC' }]"
                        size="small"
                        style="width:100px"
                        @update:model-value="(v) => opt.direction = v"
                    />
                </template>

                <template v-if="opt.type === 'merch_rule'">
                    <mt-select
                        label="Rule"
                        :model-value="opt.ruleId"
                        :options="availableRules.map(r => ({ value: r.id, label: r.name }))"
                        size="small"
                        style="flex:1"
                        @update:model-value="(v) => opt.ruleId = v"
                    />
                </template>

                <mt-button size="small" variant="ghost-danger" @click="onRemoveSortOption(index)">
                    <mt-icon name="regular-times-s" size="14" />
                </mt-button>
            </div>

            <mt-button size="small" variant="ghost" @click="onAddSortOption">+ Add Sort Option</mt-button>
        </div>

        <template #modal-footer>
            <mt-button variant="ghost" @click="onCloseModal">{{ $tc('sw-merch.general.cancel') }}</mt-button>
            <mt-button variant="primary" @click="onSaveTemplate">{{ $tc('sw-merch.general.save') }}</mt-button>
        </template>
    </sw-modal>
</div>
