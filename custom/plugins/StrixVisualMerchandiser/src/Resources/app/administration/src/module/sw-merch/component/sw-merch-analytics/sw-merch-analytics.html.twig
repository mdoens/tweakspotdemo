<div class="sw-merch-analytics">
    <mt-card>
        <template #toolbar>
            <div style="display:flex;justify-content:space-between;align-items:center;width:100%">
                <h3>{{ $tc('sw-merch.analytics.title') }}</h3>
                <div style="display:flex;gap:8px;align-items:center">
                    <mt-select
                        :model-value="period"
                        :options="periodOptions"
                        size="small"
                        style="width:160px"
                        @update:model-value="(v) => period = v"
                    />
                    <mt-button size="small" variant="ghost" @click="onExportCsv">
                        Export CSV
                    </mt-button>
                </div>
            </div>
        </template>

        <div v-if="isLoading" style="padding:40px;text-align:center">
            <mt-loader size="30px" />
        </div>

        <template v-else>
            <!-- Summary cards -->
            <div style="display:flex;gap:16px;margin-bottom:20px">
                <div style="flex:1;padding:16px;background:#f0f9ff;border-radius:8px;text-align:center">
                    <div style="font-size:28px;font-weight:700;color:#0369a1">{{ totalClicks }}</div>
                    <div style="font-size:12px;color:#758698;margin-top:4px">{{ $tc('sw-merch.analytics.totalClicks') }}</div>
                </div>
                <div style="flex:1;padding:16px;background:#f0fdf4;border-radius:8px;text-align:center">
                    <div style="font-size:28px;font-weight:700;color:#15803d">{{ uniqueProductCount }}</div>
                    <div style="font-size:12px;color:#758698;margin-top:4px">{{ $tc('sw-merch.analytics.productsTracked') }}</div>
                </div>
                <div style="flex:1;padding:16px;background:#fefce8;border-radius:8px;text-align:center">
                    <div style="font-size:28px;font-weight:700;color:#a16207">{{ (avgCtr * 100).toFixed(1) }}%</div>
                    <div style="font-size:12px;color:#758698;margin-top:4px">{{ $tc('sw-merch.analytics.avgCtrLabel') }}</div>
                </div>
                <div style="flex:1;padding:16px;background:#faf5ff;border-radius:8px;text-align:center">
                    <div style="font-size:28px;font-weight:700;color:#7c3aed">
                        {{ addToCartRate !== null ? (addToCartRate * 100).toFixed(1) + '%' : '—' }}
                    </div>
                    <div style="font-size:12px;color:#758698;margin-top:4px">{{ $tc('sw-merch.analytics.addToCartRate') }}</div>
                </div>
            </div>

            <!-- Position Heatmap -->
            <div style="margin-bottom:24px">
                <h4 style="margin-bottom:12px;font-size:14px;font-weight:600;color:#374151">
                    {{ $tc('sw-merch.analytics.positionHeatmap') }}
                </h4>
                <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:6px;max-width:600px">
                    <div
                        v-for="cell in positionHeatmap"
                        :key="cell.position"
                        :style="heatmapCellStyle(cell)"
                    >
                        <div style="font-size:11px;font-weight:700;color:#1f2937">{{ cell.position }}</div>
                        <div style="font-size:10px;color:#4b5563;margin-top:2px">{{ cell.clicks }}</div>
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:8px;margin-top:8px;font-size:11px;color:#6b7280">
                    <div style="width:14px;height:14px;background:#e5e7eb;border-radius:3px"></div>
                    {{ $tc('sw-merch.analytics.heatmapLow') }}
                    <div style="width:14px;height:14px;background:#22c55e;border-radius:3px;margin-left:8px"></div>
                    {{ $tc('sw-merch.analytics.heatmapHigh') }}
                </div>
            </div>

            <!-- Data table -->
            <div v-if="sortedAggregates.length === 0" style="padding:24px;text-align:center;color:#758698">
                <p>No click data for this period</p>
            </div>

            <table v-else style="width:100%;border-collapse:collapse;font-size:13px">
                <thead>
                    <tr style="border-bottom:2px solid #d1d9e0">
                        <th style="text-align:left;padding:8px">{{ $tc('sw-merch.analytics.productId') }}</th>
                        <th style="text-align:left;padding:8px">{{ $tc('sw-merch.analytics.date') }}</th>
                        <th style="text-align:right;padding:8px;cursor:pointer" @click="sortBy = 'totalClicks'">{{ $tc('sw-merch.analytics.totalClicks') }} ↓</th>
                        <th style="text-align:right;padding:8px;cursor:pointer" @click="sortBy = 'avgPosition'">{{ $tc('sw-merch.analytics.avgPosition') }}</th>
                        <th style="text-align:right;padding:8px;cursor:pointer" @click="sortBy = 'ctr'">{{ $tc('sw-merch.analytics.ctr') }}</th>
                    </tr>
                </thead>
                <tbody>
                    <tr v-for="agg in sortedAggregates" :key="agg.id" style="border-bottom:1px solid #e8ecf0">
                        <td style="padding:8px">
                            <div style="font-weight:600;font-size:13px">{{ getProductDisplay(agg.productId) }}</div>
                            <div v-if="getProductNumber(agg.productId)" style="font-size:11px;color:#758698;font-family:monospace">
                                {{ getProductNumber(agg.productId) }}
                            </div>
                        </td>
                        <td style="padding:8px;white-space:nowrap">{{ formatDate(agg.date) }}</td>
                        <td style="text-align:right;padding:8px;font-weight:600">{{ agg.totalClicks }}</td>
                        <td style="text-align:right;padding:8px">{{ agg.avgPosition?.toFixed(1) || '-' }}</td>
                        <td style="text-align:right;padding:8px">{{ agg.ctr ? (agg.ctr * 100).toFixed(1) + '%' : '-' }}</td>
                    </tr>
                </tbody>
            </table>
        </template>
    </mt-card>
</div>
