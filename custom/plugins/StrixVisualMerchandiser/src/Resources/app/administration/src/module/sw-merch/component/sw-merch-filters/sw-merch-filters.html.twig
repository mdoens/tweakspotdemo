<div class="sw-merch-filters">
    <!-- Per-category link -->
    <mt-card>
        <template #toolbar>
            <div style="display:flex;justify-content:space-between;align-items:center;width:100%">
                <h3>{{ $tc('sw-merch.filters.title') }} — Category</h3>
            </div>
        </template>

        <div v-if="isLoading" style="padding:40px;text-align:center"><mt-loader size="30px" /></div>

        <div v-else-if="linkedTemplate" style="padding:16px">
            <!-- Template header row -->
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
                <div style="display:flex;align-items:center;gap:10px">
                    <span style="font-weight:600;font-size:15px">{{ linkedTemplate.name }}</span>
                    <span style="font-size:11px;color:#758698;background:#f0f2f5;padding:2px 8px;border-radius:10px">
                        {{ linkedTemplate.filters.length }} {{ $tc('sw-merch.filters.filters') }}
                    </span>
                </div>
                <mt-button size="small" variant="ghost-danger" @click="onUnlinkTemplate">
                    <mt-icon name="regular-trash" size="14" />
                </mt-button>
            </div>

            <!-- Override mode -->
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;padding:10px 12px;background:#f9fafb;border-radius:6px">
                <span style="font-size:12px;font-weight:600;color:#374151;white-space:nowrap">{{ $tc('sw-merch.filters.overrideMode.active') === 'Active' ? 'Mode' : 'Modus' }}:</span>
                <mt-select
                    :model-value="categoryLink.overrideMode"
                    :options="overrideModeOptions"
                    :help-text="$tc('sw-merch.filters.helpText.overrideMode')"
                    size="small"
                    style="flex:1;max-width:200px"
                    @update:model-value="onOverrideModeChange"
                />
            </div>

            <!-- Filter list -->
            <div style="display:flex;flex-direction:column;gap:6px">
                <div
                    v-for="filter in linkedTemplate.filters"
                    :key="filter.propertyGroupId"
                    style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border:1px solid #e8ecf0;border-radius:6px;font-size:13px"
                >
                    <span style="font-weight:500">{{ getPropertyGroupName(filter.propertyGroupId) }}</span>
                    <span style="font-size:11px;color:#758698;background:#f0f2f5;padding:2px 8px;border-radius:10px">
                        {{ filter.displayType }}
                    </span>
                </div>
            </div>
        </div>

        <div v-else style="padding:32px;text-align:center;color:#758698">
            <mt-icon name="regular-image" size="36" style="opacity:0.3;margin-bottom:8px" />
            <p style="margin:0 0 12px">{{ $tc('sw-merch.filters.noLinkedTemplate') }}</p>
            <mt-select
                v-if="canEdit && templates.length > 0"
                :placeholder="$tc('sw-merch.general.linkTemplate')"
                :options="templates.map(t => ({ value: t.id, label: t.name }))"
                @update:model-value="onLinkTemplate"
                size="small"
                style="max-width:300px;margin:0 auto"
            />
        </div>
    </mt-card>

    <!-- Global templates -->
    <mt-card>
        <template #toolbar>
            <div style="display:flex;justify-content:space-between;align-items:center;width:100%">
                <h3>All Filter Templates (Global)</h3>
                <mt-button v-if="canEdit" variant="primary" size="small" @click="onCreateTemplate">
                    {{ $tc('sw-merch.filters.create') }}
                </mt-button>
            </div>
        </template>

        <div v-for="template in templates" :key="template.id" style="display:flex;align-items:center;gap:12px;padding:10px 12px;border-bottom:1px solid #e8ecf0">
            <div style="flex:1">
                <strong>{{ template.name }}</strong>
                <small style="margin-left:8px;color:#758698">{{ template.filters.length }} filters</small>
            </div>
            <mt-button v-if="canEdit" size="small" variant="ghost" @click="onEditTemplate(template)">
                <mt-icon name="regular-pencil-s" size="16" />
            </mt-button>
            <mt-button v-if="canEdit" size="small" variant="ghost-danger" @click="onDeleteTemplate(template)">
                <mt-icon name="regular-trash" size="16" />
            </mt-button>
        </div>
    </mt-card>

    <!-- Create/Edit Modal -->
    <sw-modal v-if="showCreateModal" :title="editingTemplate ? 'Edit Template' : $tc('sw-merch.filters.create')" variant="large" @modal-close="onCloseModal">
        <div style="display:flex;flex-direction:column;gap:16px">
            <mt-text-field label="Name" :model-value="newTemplate.name" @update:model-value="newTemplate.name = $event" required />
            <mt-switch label="Active" :model-value="newTemplate.active" @update:model-value="newTemplate.active = $event" />

            <h4 style="margin:8px 0 0">Filters</h4>
            <div v-for="(filter, index) in newTemplate.filters" :key="index" style="display:flex;gap:8px;align-items:center;padding:8px;border:1px solid #d1d9e0;border-radius:6px">
                <mt-select
                    label="Property Group"
                    :model-value="filter.propertyGroupId"
                    :options="propertyGroups.map(g => ({ value: g.id, label: g.translated?.name || g.name }))"
                    size="small"
                    style="flex:1"
                    @update:model-value="(v) => filter.propertyGroupId = v"
                />
                <mt-select
                    label="Display Type"
                    :model-value="filter.displayType"
                    :options="displayTypeOptions"
                    size="small"
                    style="width:140px"
                    @update:model-value="(v) => filter.displayType = v"
                />
                <mt-number-field label="Position" :model-value="filter.position" @update:model-value="filter.position = $event" :min="1" size="small" style="width:80px" />
                <mt-switch label="Collapsed" :model-value="filter.collapsed" @update:model-value="filter.collapsed = $event" size="small" />
                <mt-button size="small" variant="ghost-danger" @click="onRemoveFilter(index)">
                    <mt-icon name="regular-times-s" size="14" />
                </mt-button>
            </div>

            <mt-button size="small" variant="ghost" @click="onAddFilter">+ Add Filter</mt-button>
        </div>

        <template #modal-footer>
            <mt-button variant="ghost" @click="onCloseModal">{{ $tc('sw-merch.general.cancel') }}</mt-button>
            <mt-button variant="primary" @click="onSaveTemplate">{{ $tc('sw-merch.general.save') }}</mt-button>
        </template>
    </sw-modal>
</div>
